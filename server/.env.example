# ----- Server environment variables -----
# Copy this file to ".env" for local dev, and set the same keys in Render
# (Dashboard -> your service -> Environment).

# Port (Render sets this automatically; default 5000 locally)
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sports_meet?retryWrites=true&w=majority

# Secret used to sign admin login tokens — use a long random value in production
JWT_SECRET=change_this_to_a_long_random_string

# Default admin account (created/updated automatically on startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Frontend origin allowed by CORS (your Vercel URL). Comma-separate multiple.
# Leave empty to allow all origins (only do this for local dev).
CLIENT_URL=https://your-app.vercel.app

# Cloudinary (durable PDF storage). Get these from cloudinary.com -> Dashboard.
# If left empty, the server falls back to local disk (NOT durable on cloud hosts).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
